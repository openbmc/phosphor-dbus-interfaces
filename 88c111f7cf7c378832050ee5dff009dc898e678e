      "writtenOn": "2026-06-08T14:10:09Z",
      "side": 1,
      "message": "The proposed scheme here seems to be, read this property to decide how to interpret the reset of the interface.  Why not just make a new interface?",
      "range": {
        "startLine": 113,
        "startChar": 9,
        "endLine": 114,
        "endChar": 33
      },
      "revId": "88c111f7cf7c378832050ee5dff009dc898e678e",
