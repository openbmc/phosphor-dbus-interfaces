        "id": 1000086
      },
      "writtenOn": "2026-06-08T03:44:04Z",
      "side": 1,
      "message": "This field exists to provide a shared, lightweight, structured CPER view at the DBus layer, avoiding duplicated decoding logic and enabling multiple consumers beyond bmcweb. While today the primary consumer is bmcweb, defining it here allows other applications to easily leverage it in the future without introducing new dependencies or duplicate parsing logic.",
      "parentUuid": "f2aff513_9d591c04",
      "range": {
        "startLine": 38,
        "startChar": 15,
        "endLine": 38,
        "endChar": 75
      },
      "revId": "5d7d70750898d22e54d9ffe67952c912a3917e99",
      "serverId": "adbd0a64-1f21-4d83-b585-671fe73cb6e4"
    },
